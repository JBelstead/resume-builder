<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ profile.name }} — Resume</title>
<style>
  /* Design tokens */
  :root {
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-6: 24px;
    --space-8: 32px;
    --font-xs: 10px;
    --font-sm: 12px;
    --font-base: 14px;
    --font-lg: 16px;
    --font-xl: 20px;
    --font-2xl: 24px;
    --color-primary: #1a56db;
    --color-text: #111928;
    --color-muted: #6b7280;
    --color-border: #e5e7eb;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: var(--font-base);
    color: var(--color-text);
    line-height: 1.5;
    background: #fff;
  }

  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-8);
  }

  /* Header */
  .header { text-align: center; margin-bottom: var(--space-6); }
  .header h1 { font-size: var(--font-2xl); font-weight: 700; letter-spacing: -0.3px; }
  .header .contact {
    margin-top: var(--space-2);
    font-size: var(--font-sm);
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
  }
  .header .contact a { color: var(--color-primary); text-decoration: none; }

  /* Section */
  .section { margin-bottom: var(--space-6); }
  .section-title {
    font-size: var(--font-lg);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-1);
    margin-bottom: var(--space-3);
  }

  /* Summary */
  .summary p { font-size: var(--font-base); }

  /* Skills */
  .skills-text { font-size: var(--font-base); }

  /* Experience */
  .exp-entry { margin-bottom: var(--space-4); }
  .exp-header { display: flex; justify-content: space-between; align-items: baseline; }
  .exp-role { font-weight: 700; font-size: var(--font-base); }
  .exp-company { font-weight: 600; color: var(--color-primary); }
  .exp-dates { font-size: var(--font-sm); color: var(--color-muted); white-space: nowrap; }
  .exp-location { font-size: var(--font-sm); color: var(--color-muted); }

  .key-achievements { margin-top: var(--space-2); margin-bottom: var(--space-2); }
  .key-achievements-title {
    font-size: var(--font-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    margin-bottom: var(--space-1);
    color: var(--color-muted);
  }
  .key-achievements ul { padding-left: var(--space-4); }
  .key-achievements li { font-size: var(--font-sm); margin-bottom: 2px; }

  .exp-description { font-size: var(--font-sm); color: var(--color-muted); margin-top: var(--space-1); }

  /* Education */
  .edu-entry { margin-bottom: var(--space-3); }
  .edu-header { display: flex; justify-content: space-between; align-items: baseline; }
  .edu-degree { font-weight: 700; }
  .edu-institution { color: var(--color-primary); }
  .edu-dates { font-size: var(--font-sm); color: var(--color-muted); }
  .edu-field { font-size: var(--font-sm); color: var(--color-muted); }

  /* Certifications */
  .cert-entry { margin-bottom: var(--space-2); }
  .cert-header { display: flex; justify-content: space-between; align-items: baseline; }
  .cert-name { font-weight: 600; }
  .cert-issuer { font-size: var(--font-sm); color: var(--color-muted); }
  .cert-date { font-size: var(--font-sm); color: var(--color-muted); }

  @media print {
    body { font-size: 12px; }
    .page { padding: 12mm 16mm; }
    a { color: inherit; text-decoration: none; }
  }
</style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="header">
    <h1>{{ profile.name }}</h1>
    <div class="contact">
      {%- if profile.email %}<span>{{ profile.email }}</span>{% endif %}
      {%- if profile.phone %}<span>{{ profile.phone }}</span>{% endif %}
      {%- if profile.github_url %}<a href="{{ profile.github_url }}">{{ profile.github_url }}</a>{% endif %}
      {%- if profile.linkedin_url %}<a href="{{ profile.linkedin_url }}">{{ profile.linkedin_url }}</a>{% endif %}
      {%- if profile.website_url %}<a href="{{ profile.website_url }}">{{ profile.website_url }}</a>{% endif %}
    </div>
  </div>

  <!-- Summary -->
  {%- if summary %}
  <div class="section summary">
    <div class="section-title">Summary</div>
    <p>{{ summary }}</p>
  </div>
  {%- endif %}

  <!-- Skills -->
  {%- if skills %}
  <div class="section">
    <div class="section-title">Skills</div>
    <div class="skills-text">{{ skills | join(', ') }}</div>
  </div>
  {%- endif %}

  <!-- Experience -->
  {%- if experiences %}
  <div class="section">
    <div class="section-title">Experience</div>

    {%- if experience_highlights %}
    <div class="key-achievements">
      <div class="key-achievements-title">Key Achievements</div>
      <ul>
        {%- for highlight in experience_highlights %}
        <li>{{ highlight }}</li>
        {%- endfor %}
      </ul>
    </div>
    {%- endif %}

    {%- for exp in experiences %}
    <div class="exp-entry">
      <div class="exp-header">
        <div>
          <span class="exp-role">{{ exp.role }}</span>
          {%- if exp.company %} — <span class="exp-company">{{ exp.company }}</span>{% endif %}
          {%- if exp.location %} <span class="exp-location">({{ exp.location }})</span>{% endif %}
        </div>
        <div class="exp-dates">
          {{ exp.start_date.strftime('%b %Y') if exp.start_date else '' }}
          –
          {{ exp.end_date.strftime('%b %Y') if exp.end_date else 'Present' }}
        </div>
      </div>
      {%- if exp.description %}
      <div class="exp-description">{{ exp.description }}</div>
      {%- endif %}
    </div>
    {%- endfor %}
  </div>
  {%- endif %}

  <!-- Education -->
  {%- if educations %}
  <div class="section">
    <div class="section-title">Education</div>
    {%- for edu in educations %}
    <div class="edu-entry">
      <div class="edu-header">
        <div>
          <span class="edu-degree">{{ edu.degree }}</span>
          {%- if edu.field_of_study %} in <span class="edu-field">{{ edu.field_of_study }}</span>{% endif %}
          {%- if edu.institution %} — <span class="edu-institution">{{ edu.institution }}</span>{% endif %}
        </div>
        <div class="edu-dates">
          {{ edu.start_date.strftime('%Y') if edu.start_date else '' }}
          {%- if edu.end_date %} – {{ edu.end_date.strftime('%Y') }}{% endif %}
        </div>
      </div>
    </div>
    {%- endfor %}
  </div>
  {%- endif %}

  <!-- Certifications -->
  {%- if certifications %}
  <div class="section">
    <div class="section-title">Certifications</div>
    {%- for cert in certifications %}
    <div class="cert-entry">
      <div class="cert-header">
        <div>
          <span class="cert-name">{{ cert.name }}</span>
          {%- if cert.issuer %} — <span class="cert-issuer">{{ cert.issuer }}</span>{% endif %}
        </div>
        <div class="cert-date">
          {%- if cert.issue_date %}{{ cert.issue_date.strftime('%b %Y') }}{% endif %}
          {%- if cert.expiry_date %} – {{ cert.expiry_date.strftime('%b %Y') }}{% endif %}
        </div>
      </div>
    </div>
    {%- endfor %}
  </div>
  {%- endif %}

</div>
</body>
</html>
